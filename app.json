{
  "expo": {
    "name": "El Sargento",
    "slug": "el-sargento",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "elsargento",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A2F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elsargento.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "El Sargento necesita el micrófono para que puedas hablarle directamente, recluta.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.elsargento.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B3A2F"
      },
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "El Sargento necesita el micrófono para escuchar tus reportes, recluta."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1B3A2F"
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
