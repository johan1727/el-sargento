# ─────────────────────────────────────────────────────────────
# El Sargento — variables de entorno
# Copia este archivo a `.env` y rellena los valores.
# Las que empiezan con EXPO_PUBLIC_ se exponen al cliente (Expo).
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Solo backend / edge functions — NUNCA exponer en el cliente.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Gemini (https://aistudio.google.com/app/apikey)
# NOTA: para producción mover las llamadas a Gemini a una Edge Function
# y NO exponer la API key. Para desarrollo local usamos EXPO_PUBLIC_.
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# RevenueCat (App Store + Google Play)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=YOUR_RC_IOS_KEY
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=YOUR_RC_ANDROID_KEY
